#!/usr/bin/env bash

export PATH="/opt/homebrew/bin:/usr/local/bin:/bin:/usr/bin:/usr/sbin:/sbin"

CONFIG_DIR="${CONFIG_DIR:-$HOME/.config/sketchybar}"
PLUGIN_DIR="$CONFIG_DIR/plugins"

mkdir -p "$CONFIG_DIR/cache"

# Palette sampled toward your terminal/window theme:
# deep teal base, pale cyan text, copper/warm wallpaper accent.
BAR_BG=0x00000000
MAIN_CELL=0x00000000
PANEL=0x66002434
PANEL_STRONG=0xcc00283a
BORDER=0x44c77d47

TEXT=0xffd6f3f0
MUTED=0xff82a9ad
CYAN=0xff7bdff2
GREEN=0xffa6e3a1
BLUE=0xff89b4fa
YELLOW=0xfff9e2af
RED=0xfff38ba8
ORANGE=0xffc77d47
TZ_BLUE=0xffa6c8ff
TZ_GREEN=0xffb9f6ca
TZ_ORANGE=0xffffb86c
TZ_CYAN=0xff9bf6ff
TZ_NEUTRAL=0xffd0dce0
TZ_RED=0xffff9db4

BAR_HEIGHT=170
BAR_RADIUS=20
BAR_MARGIN=340
BAR_PADDING_LEFT=220
BAR_PADDING_RIGHT=322
STAT_TILE_HEIGHT=140
STAT_RADIUS=12
STAT_ITEM_GAP=20
STAT_STATS_SPAN_WIDTH=930
STAT_GRAPH_COUNT=4
STAT_GAP_COUNT=$((STAT_GRAPH_COUNT - 1))
STAT_GRAPH_WIDTH=$(((STAT_STATS_SPAN_WIDTH - STAT_GAP_COUNT * STAT_ITEM_GAP) / STAT_GRAPH_COUNT))
STAT_STATS_REMAINDER=$((STAT_STATS_SPAN_WIDTH - STAT_GRAPH_COUNT * STAT_GRAPH_WIDTH - STAT_GAP_COUNT * STAT_ITEM_GAP))
STAT_SWAP_MEM_GAP=$((STAT_ITEM_GAP + STAT_STATS_REMAINDER))
STAT_LABEL_TOP_INSET=8
STAT_LABEL_DOWN_SHIFT=110
STAT_LABEL_Y_OFFSET=$((STAT_TILE_HEIGHT / 2 - STAT_LABEL_TOP_INSET - STAT_LABEL_DOWN_SHIFT))
STAT_PILL_BG=0xff182c2f
STAT_PILL_HEIGHT=22
STAT_PILL_Y_OFFSET=$((STAT_LABEL_Y_OFFSET + 2))
STAT_PILL_RADIUS=6
STAT_PILL_X_PADDING=2
STAT_LABEL_CHAR_WIDTH=9
STAT_CPU_LABEL_WIDTH_TRIM=8
STAT_CPU_LABEL_WIDTH=$((18 * STAT_LABEL_CHAR_WIDTH + 2 * STAT_PILL_X_PADDING - STAT_CPU_LABEL_WIDTH_TRIM))
STAT_SMALL_LABEL_WIDTH=$((16 * STAT_LABEL_CHAR_WIDTH + 2 * STAT_PILL_X_PADDING))
STAT_CPU_LABEL_OFFSET=$((-(STAT_GRAPH_WIDTH + STAT_CPU_LABEL_WIDTH) / 2))
STAT_SMALL_LABEL_OFFSET=$((-(STAT_GRAPH_WIDTH + STAT_SMALL_LABEL_WIDTH) / 2))
CLOCK_TILE_HEIGHT=$STAT_TILE_HEIGHT
CLOCK_LEFT_WIDTH=165
CLOCK_DATE_WIDTH=82
CLOCK_TIME_WIDTH=180
CLOCK_VPN_WIDTH=$((CLOCK_LEFT_WIDTH + CLOCK_DATE_WIDTH + CLOCK_TIME_WIDTH))
CLOCK_STAT_GAP=$STAT_ITEM_GAP
CLOCK_TILE_LABEL_OFFSET=-165
CLOCK_LEFT_TZ_LABEL_OFFSET=$((-CLOCK_LEFT_WIDTH))
MUSIC_GAP=$((STAT_ITEM_GAP + 15))
MUSIC_CONTROL_WIDTH=46
MUSIC_LEFT_INSET=18
MUSIC_RIGHT_INSET=$MUSIC_LEFT_INSET
MUSIC_BUTTON_GAP=5
MUSIC_VOLUME_WIDTH=34
MUSIC_VOLUME_GAP=7
MUSIC_VOLUME_BUTTON_HEIGHT=34
MUSIC_VOLUME_BUTTON_RADIUS=8
MUSIC_VOLUME_POPUP_HEIGHT=40
MUSIC_VOLUME_POPUP_Y_OFFSET=130
MUSIC_PREV_WIDTH=46
MUSIC_PLAY_WIDTH=64
MUSIC_CONTROL_HEIGHT=$STAT_TILE_HEIGHT
MUSIC_BUTTON_HEIGHT=72
MUSIC_BUTTON_RADIUS=12
MUSIC_BUTTON_BG=0x33000000
MUSIC_TRACK_WIDTH=360
MUSIC_LABEL_WIDTH=$MUSIC_TRACK_WIDTH
MUSIC_TITLE_LABEL_PADDING=10
MUSIC_ARTIST_LABEL_PADDING=10
MUSIC_ARTIST_LABEL_OFFSET=$((-(MUSIC_TRACK_WIDTH + 0)))
MUSIC_TRACK_HEIGHT=$STAT_TILE_HEIGHT
MUSIC_RADIUS=$STAT_RADIUS
MUSIC_PAGE_CHARS=60
VOLUME_FULL_SCRIPT="hs -c 'nativeVolumeUp()'"
VOLUME_HALF_SCRIPT="hs -c 'nativeVolumeDown()'"
VOLUME_MUTE_SCRIPT="hs -c 'nativeMute()'"
CLOCK_STOPWATCH_TIME_OFFSET=60
STOPWATCH_MENU_TIME_RIGHT_OFFSET=$((BAR_MARGIN + BAR_PADDING_RIGHT + STAT_STATS_SPAN_WIDTH + CLOCK_STAT_GAP + CLOCK_VPN_WIDTH - CLOCK_STOPWATCH_TIME_OFFSET))

# Clear all items on reload.
# Temporarily disabled while tuning stats overlays so graph histories survive reloads.
# sketchybar --remove '/.*/' 2>/dev/null

##### Bottom gutter bar #####
# Keep the asymmetric fake margin layout:
# real margin = 340; internal right padding fakes the 640px right boundary.
sketchybar --bar \
  position=bottom \
  height=$BAR_HEIGHT \
  margin=$BAR_MARGIN \
  color=$BAR_BG \
  corner_radius=$BAR_RADIUS \
  border_width=0 \
  blur_radius=0 \
  padding_left=$BAR_PADDING_LEFT \
  padding_right=$BAR_PADDING_RIGHT \
  sticky=on \
  topmost=window \
  shadow=off \
  font_smoothing=on

##### Defaults #####
sketchybar --default \
  padding_left=3 \
  padding_right=3 \
  icon.font="Hack Nerd Font:Bold:13.0" \
  label.font="Hack Nerd Font:Bold:13.0" \
  icon.color=$TEXT \
  label.color=$TEXT \
  icon.padding_left=4 \
  icon.padding_right=4 \
  label.padding_left=4 \
  label.padding_right=4

##### Right gutter: music #####

sketchybar --add item music.left_pad right \
  --set music.left_pad \
    width=$MUSIC_LEFT_INSET \
    icon.drawing=off \
    label.drawing=off \
    background.drawing=off \
    padding_left=0 \
    padding_right=0

sketchybar --add item music.prev right \
  --set music.prev \
    width=$MUSIC_PREV_WIDTH \
    icon="âŹ®" \
    icon.font="Hack Nerd Font:Bold:22.0" \
    icon.width=$MUSIC_PREV_WIDTH \
    icon.align=center \
    icon.padding_left=0 \
    icon.padding_right=0 \
    label.drawing=off \
    background.drawing=on \
    background.color=$MUSIC_BUTTON_BG \
    background.height=$MUSIC_BUTTON_HEIGHT \
    background.corner_radius=$MUSIC_BUTTON_RADIUS \
    padding_left=0 \
    padding_right=0 \
    click_script="nowplaying-cli previous"

sketchybar --add item music.prev_play_gap right \
  --set music.prev_play_gap \
    width=$MUSIC_BUTTON_GAP \
    icon.drawing=off \
    label.drawing=off \
    background.drawing=off \
    padding_left=0 \
    padding_right=0

sketchybar --add item music.play right \
  --set music.play \
    width=$MUSIC_PLAY_WIDTH \
    icon="â–¶" \
    icon.font="Hack Nerd Font:Bold:30.0" \
    icon.width=$MUSIC_PLAY_WIDTH \
    icon.align=center \
    icon.padding_left=0 \
    icon.padding_right=0 \
    label.drawing=off \
    background.drawing=on \
    background.color=$MUSIC_BUTTON_BG \
    background.height=$MUSIC_BUTTON_HEIGHT \
    background.corner_radius=$MUSIC_BUTTON_RADIUS \
    background.image.drawing=off \
    background.image.scale=1.0 \
    background.image.corner_radius=$MUSIC_BUTTON_RADIUS \
    padding_left=0 \
    padding_right=0 \
    click_script="nowplaying-cli togglePlayPause"

sketchybar --add item music.play_next_gap right \
  --set music.play_next_gap \
    width=$MUSIC_BUTTON_GAP \
    icon.drawing=off \
    label.drawing=off \
    background.drawing=off \
    padding_left=0 \
    padding_right=0

sketchybar --add item music.next right \
  --set music.next \
    width=$MUSIC_CONTROL_WIDTH \
    icon="âŹ­" \
    icon.font="Hack Nerd Font:Bold:22.0" \
    icon.width=$MUSIC_CONTROL_WIDTH \
    icon.align=center \
    icon.padding_left=0 \
    icon.padding_right=0 \
    label.drawing=off \
    background.drawing=on \
    background.color=$MUSIC_BUTTON_BG \
    background.height=$MUSIC_BUTTON_HEIGHT \
    background.corner_radius=$MUSIC_BUTTON_RADIUS \
    padding_left=0 \
    padding_right=0 \
    click_script="nowplaying-cli next"

sketchybar --add item music.artist right \
  --set music.artist \
    icon.drawing=off \
    label="Now Playing" \
    width=0 \
    label.font="Hack Nerd Font:Bold:16.0" \
    label.max_chars=$MUSIC_PAGE_CHARS \
    label.width=$MUSIC_LABEL_WIDTH \
    label.align=left \
    label.padding_left=$MUSIC_ARTIST_LABEL_PADDING \
    label.padding_right=12 \
    label.y_offset=10 \
    label.color=$TEXT \
    background.drawing=off \
    padding_left=0 \
    padding_right=$MUSIC_ARTIST_LABEL_OFFSET \
    click_script='open -a "Amazon Music"'

sketchybar --add item music right \
  --set music \
    icon.drawing=off \
    label="Nothing playing" \
    width=$MUSIC_TRACK_WIDTH \
    label.font="Hack Nerd Font:Bold:16.0" \
    label.max_chars=$MUSIC_PAGE_CHARS \
    label.width=$MUSIC_LABEL_WIDTH \
    label.align=left \
    label.padding_left=$MUSIC_TITLE_LABEL_PADDING \
    label.padding_right=12 \
    label.y_offset=-11 \
    scroll_texts=off \
    background.drawing=off \
    padding_left=0 \
    padding_right=0 \
    click_script='open -a "Amazon Music"'

sketchybar --add item music.volume_gap right \
  --set music.volume_gap \
    width=$MUSIC_VOLUME_GAP \
    icon.drawing=off \
    label.drawing=off \
    background.drawing=off \
    padding_left=0 \
    padding_right=0

sketchybar --add item music.volume right \
  --set music.volume \
    width=$MUSIC_VOLUME_WIDTH \
    icon.drawing=off \
    label.drawing=off \
    background.drawing=off \
    padding_left=0 \
    padding_right=0 \
    popup.drawing=on \
    popup.horizontal=off \
    popup.align=center \
    popup.height=$MUSIC_VOLUME_POPUP_HEIGHT \
    popup.y_offset=$MUSIC_VOLUME_POPUP_Y_OFFSET \
    popup.background.drawing=off

VOLUME_POPUP_COMMON=(
  width=$MUSIC_VOLUME_WIDTH
  icon.font="Apple Color Emoji:Regular:12.0"
  icon.width=$MUSIC_VOLUME_WIDTH
  icon.align=center
  icon.padding_left=0
  icon.padding_right=0
  label.drawing=off
  background.drawing=on
  background.color=$MUSIC_BUTTON_BG
  background.height=$MUSIC_VOLUME_BUTTON_HEIGHT
  background.corner_radius=$MUSIC_VOLUME_BUTTON_RADIUS
  padding_left=0
  padding_right=0
)

sketchybar --add item music.volume.full popup.music.volume \
  --set music.volume.full "${VOLUME_POPUP_COMMON[@]}" \
    icon="đź”Š" \
    click_script="$VOLUME_FULL_SCRIPT"

sketchybar --add item music.volume.half popup.music.volume \
  --set music.volume.half "${VOLUME_POPUP_COMMON[@]}" \
    icon="đź”‰" \
    click_script="$VOLUME_HALF_SCRIPT"

sketchybar --add item music.volume.mute popup.music.volume \
  --set music.volume.mute "${VOLUME_POPUP_COMMON[@]}" \
    icon="đź”‡" \
    click_script="$VOLUME_MUTE_SCRIPT"

sketchybar --add item music.right_pad right \
  --set music.right_pad \
    width=$MUSIC_RIGHT_INSET \
    icon.drawing=off \
    label.drawing=off \
    background.drawing=off \
    padding_left=0 \
    padding_right=0

sketchybar --add bracket music.tile music.left_pad music.prev music.prev_play_gap music.play music.play_next_gap music.next music.artist music music.volume_gap music.volume music.right_pad \
  --set music.tile \
    background.color=$PANEL_STRONG \
    background.height=$MUSIC_TRACK_HEIGHT \
    background.corner_radius=$STAT_RADIUS \
    background.border_width=0 \
    background.border_color=0x00000000

sketchybar --set music \
  script="$PLUGIN_DIR/music.sh" \
  update_freq=4

# Gap between music controls and clock pill.
sketchybar --add item gap.clock_music right \
  --set gap.clock_music \
    width=$MUSIC_GAP \
    icon.drawing=off \
    label.drawing=off \
    background.drawing=off \
    padding_left=0 \
    padding_right=0

##### Right gutter: integrated two-clock pill #####

sketchybar --add item clock.vpn right \
  --set clock.vpn \
    icon.drawing=off \
    label="Mullvad ..." \
    width=0 \
    label.font="Hack Nerd Font:Bold:15.0" \
    label.max_chars=44 \
    label.width=$CLOCK_VPN_WIDTH \
    label.align=center \
    label.color=$TEXT \
    label.y_offset=-43 \
    background.drawing=off \
    padding_left=0 \
    padding_right=$CLOCK_TILE_LABEL_OFFSET \
    script="$PLUGIN_DIR/mullvad.sh" \
    update_freq=10

sketchybar --add item clock.day right \
  --set clock.day \
    icon.drawing=off \
    label="MON" \
    width=0 \
    label.font="Hack Nerd Font:Bold:18.0" \
    label.width=$CLOCK_VPN_WIDTH \
    label.align=center \
    label.color=$CYAN \
    label.y_offset=28 \
    background.drawing=off \
    padding_left=0 \
    padding_right=$CLOCK_TILE_LABEL_OFFSET

sketchybar --add item clock.month right \
  --set clock.month \
    icon.drawing=off \
    label="JUN 22" \
    width=0 \
    label.font="Hack Nerd Font:Bold:18.0" \
    label.width=$CLOCK_VPN_WIDTH \
    label.align=center \
    label.color=$CYAN \
    label.y_offset=-10 \
    background.drawing=off \
    padding_left=0 \
    padding_right=$CLOCK_TILE_LABEL_OFFSET

# Selectable secondary timezone label. Its text is drawn separately from the
# time value; clock_left_click.sh keeps the lower label band mode-independent.
sketchybar --add item clock.left.tz right \
  --set clock.left.tz \
    icon.drawing=off \
    label="AZ â–ľ" \
    width=0 \
    label.font="Hack Nerd Font:Bold:17.0" \
    label.width=$CLOCK_LEFT_WIDTH \
    label.align=center \
    label.color=$BLUE \
    label.y_offset=-6 \
    label.padding_left=14 \
    label.padding_right=-14 \
    background.drawing=off \
    padding_left=0 \
    padding_right=$CLOCK_LEFT_TZ_LABEL_OFFSET \
    click_script="sketchybar --set clock.left popup.drawing=toggle"

sketchybar --add item clock.left right \
  --set clock.left \
    width=$CLOCK_LEFT_WIDTH \
    icon.drawing=off \
    label="--:--" \
    label.font="Hack Nerd Font:Bold:24.0" \
    label.color=$TEXT \
    label.width=$CLOCK_LEFT_WIDTH \
    label.align=center \
    label.y_offset=22 \
    label.padding_left=0 \
    label.padding_right=0 \
    background.drawing=off \
    padding_left=14 \
    padding_right=0 \
    popup.drawing=off \
    popup.horizontal=off \
    popup.height=34 \
    popup.blur_radius=20 \
    popup.background.color=$PANEL_STRONG \
    popup.background.corner_radius=14 \
    script="$PLUGIN_DIR/clock.sh" \
    update_freq=5 \
    click_script="$PLUGIN_DIR/clock_left_click.sh"

sketchybar --add item clock.date right \
  --set clock.date \
    width=$CLOCK_DATE_WIDTH \
    icon.drawing=off \
    label.drawing=off \
    background.drawing=off \
    padding_left=-18 \
    padding_right=0 \
    click_script="$PLUGIN_DIR/mullvad.sh click"

# Primary Arizona clock.
sketchybar --add item clock right \
  --set clock \
    width=$CLOCK_TIME_WIDTH \
    icon.drawing=off \
    label="12:52 PM" \
    label.font="Hack Nerd Font:Bold:37.0" \
    label.color=$TEXT \
    label.width=$CLOCK_TIME_WIDTH \
    label.align=center \
    label.y_offset=11 \
    label.padding_left=0 \
    label.padding_right=0 \
    background.drawing=off \
    padding_left=0 \
    padding_right=8 \
    script="$PLUGIN_DIR/clock.sh" \
    update_freq=5 \
    click_script="open -a Calendar"

# One shared visible clock background.
sketchybar --add bracket clock.tile clock.left clock.date clock \
  --set clock.tile \
    background.color=$PANEL_STRONG \
    background.height=$CLOCK_TILE_HEIGHT \
    background.corner_radius=$STAT_RADIUS \
    background.border_width=0 \
    background.border_color=0x00000000

# Popup timezone options.
TZ_POPUP_COMMON=(
  icon.drawing=off
  width=170
  label.font="Hack Nerd Font:Bold:15.0"
  label.color=$TEXT
  label.align=left
  background.height=28
  background.corner_radius=8
  background.color=0x22000000
)

sketchybar --add item clock.tz.et popup.clock.left \
  --set clock.tz.et "${TZ_POPUP_COMMON[@]}" \
    label="Eastern" \
    label.color=$TZ_BLUE \
    click_script="$PLUGIN_DIR/clock_select.sh America/New_York ET $TZ_BLUE"

sketchybar --add item clock.tz.ct popup.clock.left \
  --set clock.tz.ct "${TZ_POPUP_COMMON[@]}" \
    label="Central" \
    label.color=$TZ_GREEN \
    click_script="$PLUGIN_DIR/clock_select.sh America/Chicago CT $TZ_GREEN"

sketchybar --add item clock.tz.mt popup.clock.left \
  --set clock.tz.mt "${TZ_POPUP_COMMON[@]}" \
    label="Mountain" \
    label.color=$YELLOW \
    click_script="$PLUGIN_DIR/clock_select.sh America/Denver MT $YELLOW"

sketchybar --add item clock.tz.pt popup.clock.left \
  --set clock.tz.pt "${TZ_POPUP_COMMON[@]}" \
    label="Pacific" \
    label.color=$TZ_ORANGE \
    click_script="$PLUGIN_DIR/clock_select.sh America/Los_Angeles PT $TZ_ORANGE"

sketchybar --add item clock.tz.az popup.clock.left \
  --set clock.tz.az "${TZ_POPUP_COMMON[@]}" \
    label="Arizona" \
    label.color=$TZ_CYAN \
    click_script="$PLUGIN_DIR/clock_select.sh America/Phoenix AZ $TZ_CYAN"

sketchybar --add item clock.tz.utc popup.clock.left \
  --set clock.tz.utc "${TZ_POPUP_COMMON[@]}" \
    label="UTC" \
    label.color=$TZ_NEUTRAL \
    click_script="$PLUGIN_DIR/clock_select.sh UTC UTC $TZ_NEUTRAL"

sketchybar --add item clock.tz.london popup.clock.left \
  --set clock.tz.london "${TZ_POPUP_COMMON[@]}" \
    label="London" \
    label.color=$TZ_BLUE \
    click_script="$PLUGIN_DIR/clock_select.sh Europe/London LDN $TZ_BLUE"

sketchybar --add item clock.tz.china popup.clock.left \
  --set clock.tz.china "${TZ_POPUP_COMMON[@]}" \
    label="China" \
    label.color=$TZ_RED \
    click_script="$PLUGIN_DIR/clock_select.sh Asia/Shanghai CHN $TZ_RED"

sketchybar --add item clock.tz.tokyo popup.clock.left \
  --set clock.tz.tokyo "${TZ_POPUP_COMMON[@]}" \
    label="Tokyo" \
    label.color=$TZ_RED \
    click_script="$PLUGIN_DIR/clock_select.sh Asia/Tokyo TYO $TZ_RED"

sketchybar --add item clock.tz.stopwatch popup.clock.left \
  --set clock.tz.stopwatch "${TZ_POPUP_COMMON[@]}" \
    label="WATCH 00:00" \
    label.color=$GREEN \
    updates=when_shown \
    update_freq=0 \
    script="$PLUGIN_DIR/stopwatch.sh" \
    click_script="STOPWATCH_MENU_TIME_RIGHT_OFFSET=$STOPWATCH_MENU_TIME_RIGHT_OFFSET $PLUGIN_DIR/stopwatch.sh menu_click"

sketchybar --add event clock_update
sketchybar --subscribe clock clock_update
sketchybar --subscribe clock.left clock_update
sketchybar --subscribe clock.vpn clock_update

##### Right cluster: graph-only stats with anchored overlays #####
# Add right-side graphs/gaps in this order so visible order is:
# SWP | 22px | MEM | 20px | GPU | 20px | CPU.
# 930px span = 4 equal graph cells + 3 gaps; the 2px integer remainder
# rides in the leftmost stat gap so the swap-left edge lands exactly.

# CPU graph, rightmost.
sketchybar --add graph cpu.total right $STAT_GRAPH_WIDTH \
  --set cpu.total \
    icon.drawing=off \
    label.drawing=off \
    background.color=0x00000000 \
    background.height=$STAT_TILE_HEIGHT \
    background.corner_radius=$STAT_RADIUS \
    graph.color=$CYAN \
    graph.fill_color=0x337bdff2 \
    graph.line_width=1.5 \
    padding_left=-1 \
    padding_right=0

sketchybar --add item gap.mem_cpu right \
  --set gap.mem_cpu \
    width=$STAT_ITEM_GAP \
    icon.drawing=off \
    label.drawing=off \
    background.drawing=off \
    padding_left=0 \
    padding_right=0

# GPU graph, next to CPU.
sketchybar --add graph gpu.graph right $STAT_GRAPH_WIDTH \
  --set gpu.graph \
    icon.drawing=off \
    label.drawing=off \
    background.color=0x00000000 \
    background.height=$STAT_TILE_HEIGHT \
    background.corner_radius=$STAT_RADIUS \
    graph.color=$GREEN \
    graph.fill_color=0x33a6e3a1 \
    graph.line_width=1.5 \
    padding_left=-1 \
    padding_right=0

sketchybar --add item gap.mem_gpu right \
  --set gap.mem_gpu \
    width=$STAT_ITEM_GAP \
    icon.drawing=off \
    label.drawing=off \
    background.drawing=off \
    padding_left=0 \
    padding_right=0

# MEM graph.
sketchybar --add graph mem.graph right $STAT_GRAPH_WIDTH \
  --set mem.graph \
    icon.drawing=off \
    label.drawing=off \
    background.color=0x00000000 \
    background.height=$STAT_TILE_HEIGHT \
    background.corner_radius=$STAT_RADIUS \
    graph.color=$BLUE \
    graph.fill_color=0x3389b4fa \
    graph.line_width=1.5 \
    padding_left=-1 \
    padding_right=0

sketchybar --add item gap.swap_mem right \
  --set gap.swap_mem \
    width=$STAT_SWAP_MEM_GAP \
    icon.drawing=off \
    label.drawing=off \
    background.drawing=off \
    padding_left=0 \
    padding_right=0

# SWP graph, leftmost of stats cluster.
sketchybar --add graph swap.graph right $STAT_GRAPH_WIDTH \
  --set swap.graph \
    icon.drawing=off \
    label.drawing=off \
    background.color=0x00000000 \
    background.height=$STAT_TILE_HEIGHT \
    background.corner_radius=$STAT_RADIUS \
    graph.color=$ORANGE \
    graph.fill_color=0x33c77d47 \
    graph.line_width=1.5 \
    padding_left=-1 \
    padding_right=0

sketchybar --add item gap.clock_swap right \
  --set gap.clock_swap \
    width=$CLOCK_STAT_GAP \
    icon.drawing=off \
    label.drawing=off \
    background.drawing=off \
    padding_left=0 \
    padding_right=0

# All gutter content is right-positioned. Right-side order is built from the
# right edge inward, so this keeps the visible layout: music | clock | stats.
RIGHT_GUTTER_ORDER=(
  cpu.total
  gap.mem_cpu
  gpu.graph
  gap.mem_gpu
  mem.graph
  gap.swap_mem
  swap.graph
  gap.clock_swap
  clock
  clock.date
  clock.left.tz
  clock.left
  gap.clock_music
  music.right_pad
  music.volume
  music.volume_gap
  music
  music.artist
  music.next
  music.play_next_gap
  music.play
  music.prev_play_gap
  music.prev
  music.left_pad
)

sketchybar --set '/^(music(\.(left_pad|prev|prev_play_gap|play|play_next_gap|next|artist|volume_gap|volume|right_pad))?|gap\.(clock_music|clock_swap)|clock(\.(vpn|day|month|left(\.tz)?|date))?)$/' position=right
sketchybar --reorder "${RIGHT_GUTTER_ORDER[@]}"
sketchybar --move clock.left.tz after clock.left
sketchybar --move clock.day after clock
sketchybar --move clock.month after clock
sketchybar --move clock.vpn after clock

# Tile backgrounds.
sketchybar --add bracket cpu.tile cpu.total \
  --set cpu.tile \
    background.color=$PANEL_STRONG \
    background.height=$STAT_TILE_HEIGHT \
    background.corner_radius=$STAT_RADIUS \
    background.border_width=0 \
    background.border_color=0x00000000

sketchybar --add bracket gpu.tile gpu.graph \
  --set gpu.tile \
    background.color=$PANEL_STRONG \
    background.height=$STAT_TILE_HEIGHT \
    background.corner_radius=$STAT_RADIUS \
    background.border_width=0 \
    background.border_color=0x00000000

sketchybar --add bracket mem.tile mem.graph \
  --set mem.tile \
    background.color=$PANEL_STRONG \
    background.height=$STAT_TILE_HEIGHT \
    background.corner_radius=$STAT_RADIUS \
    background.border_width=0 \
    background.border_color=0x00000000

sketchybar --add bracket swap.tile swap.graph \
  --set swap.tile \
    background.color=$PANEL_STRONG \
    background.height=$STAT_TILE_HEIGHT \
    background.corner_radius=$STAT_RADIUS \
    background.border_width=0 \
    background.border_color=0x00000000

# Fitted external backing. The real bar is transparent; this bracket tracks the
# first/last visible objects without adding extra end padding.
sketchybar --add bracket main.tile music.left_pad music.prev music.prev_play_gap music.play music.play_next_gap music.next music.artist music music.volume_gap music.volume music.right_pad gap.clock_music clock.left clock.date clock gap.clock_swap swap.graph gap.swap_mem mem.graph gap.mem_gpu gpu.graph gap.mem_cpu cpu.total \
  --set main.tile \
    background.color=$MAIN_CELL \
    background.height=$STAT_TILE_HEIGHT \
    background.corner_radius=$STAT_RADIUS \
    background.border_width=0 \
    background.border_color=0x00000000

# CPU overlay, centered across cpu.total.
sketchybar --add item cpu.stat_label right \
  --set cpu.stat_label \
    icon.drawing=off \
    label="CPU 0.00 0.00 0.00" \
    width=0 \
    label.width=$STAT_CPU_LABEL_WIDTH \
    label.align=center \
    label.font="Hack Nerd Font:Bold:15.0" \
    label.color=$CYAN \
    label.y_offset=$STAT_LABEL_Y_OFFSET \
    label.padding_left=0 \
    label.padding_right=0 \
    label.background.drawing=on \
    label.background.color=$STAT_PILL_BG \
    label.background.height=$STAT_PILL_HEIGHT \
    label.background.corner_radius=$STAT_PILL_RADIUS \
    label.background.y_offset=$STAT_PILL_Y_OFFSET \
    background.drawing=off \
    padding_left=0 \
    padding_right=$STAT_CPU_LABEL_OFFSET

sketchybar --move cpu.stat_label after cpu.total

# GPU overlay, centered across gpu.graph.
sketchybar --add item gpu.stat_label right \
  --set gpu.stat_label \
    icon.drawing=off \
    label="GPU 0.00 0.00 0.00" \
    width=0 \
    label.width=$STAT_CPU_LABEL_WIDTH \
    label.align=center \
    label.font="Hack Nerd Font:Bold:15.0" \
    label.color=$GREEN \
    label.y_offset=$STAT_LABEL_Y_OFFSET \
    label.padding_left=0 \
    label.padding_right=0 \
    label.background.drawing=on \
    label.background.color=$STAT_PILL_BG \
    label.background.height=$STAT_PILL_HEIGHT \
    label.background.corner_radius=$STAT_PILL_RADIUS \
    label.background.y_offset=$STAT_PILL_Y_OFFSET \
    background.drawing=off \
    padding_left=0 \
    padding_right=$STAT_CPU_LABEL_OFFSET

sketchybar --move gpu.stat_label after gpu.graph

# MEM overlay, centered across mem.graph.
sketchybar --add item mem.stat_label right \
  --set mem.stat_label \
    icon.drawing=off \
    label="MEM 0/0G C0.0G" \
    width=0 \
    label.width=$STAT_SMALL_LABEL_WIDTH \
    label.align=center \
    label.font="Hack Nerd Font:Bold:15.0" \
    label.color=$BLUE \
    label.y_offset=$STAT_LABEL_Y_OFFSET \
    label.padding_left=0 \
    label.padding_right=0 \
    label.background.drawing=on \
    label.background.color=$STAT_PILL_BG \
    label.background.height=$STAT_PILL_HEIGHT \
    label.background.corner_radius=$STAT_PILL_RADIUS \
    label.background.y_offset=$STAT_PILL_Y_OFFSET \
    background.drawing=off \
    padding_left=0 \
    padding_right=$STAT_SMALL_LABEL_OFFSET

sketchybar --move mem.stat_label after mem.graph

# SWP overlay, centered across swap.graph.
sketchybar --add item swap.stat_label right \
  --set swap.stat_label \
    icon.drawing=off \
    label="SWP 0.0G +0M/5m" \
    width=0 \
    label.width=$STAT_SMALL_LABEL_WIDTH \
    label.align=center \
    label.font="Hack Nerd Font:Bold:15.0" \
    label.color=$ORANGE \
    label.y_offset=$STAT_LABEL_Y_OFFSET \
    label.padding_left=0 \
    label.padding_right=0 \
    label.background.drawing=on \
    label.background.color=$STAT_PILL_BG \
    label.background.height=$STAT_PILL_HEIGHT \
    label.background.corner_radius=$STAT_PILL_RADIUS \
    label.background.y_offset=$STAT_PILL_Y_OFFSET \
    background.drawing=off \
    padding_left=0 \
    padding_right=$STAT_SMALL_LABEL_OFFSET

sketchybar --move swap.stat_label after swap.graph

##### Stats driver â€” keep after all stat items #####
sketchybar --add item stats.driver right \
  --set stats.driver \
    drawing=off \
    updates=on \
    update_freq=2 \
    script="$PLUGIN_DIR/stats_push.sh"

sketchybar --update
