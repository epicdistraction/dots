#!/usr/bin/env bash

export PATH="/opt/homebrew/bin:/usr/local/bin:/bin:/usr/bin:/usr/sbin:/sbin"

CONFIG_DIR="${CONFIG_DIR:-$HOME/.config/sketchybar}"
PLUGIN_DIR="$CONFIG_DIR/plugins"

mkdir -p "$CONFIG_DIR/cache"

# Palette sampled toward your terminal/window theme:
# deep teal base, pale cyan text, copper/warm wallpaper accent.
BAR_BG=0x00000000
MAIN_CELL=0x66003040
PANEL=0x66002434
PANEL_STRONG=0xaa002434
BORDER=0x44c77d47

TEXT=0xffd6f3f0
MUTED=0xff82a9ad
CYAN=0xff7bdff2
GREEN=0xffa6e3a1
BLUE=0xff89b4fa
YELLOW=0xfff9e2af
RED=0xfff38ba8
ORANGE=0xffc77d47

BAR_HEIGHT=120
BAR_RADIUS=20
STAT_TILE_HEIGHT=120
STAT_RADIUS=12
STAT_ITEM_GAP=20
STAT_LABEL_Y_OFFSET=47
CLOCK_TILE_HEIGHT=$STAT_TILE_HEIGHT
MUSIC_GAP=20
MUSIC_CONTROL_WIDTH=46
MUSIC_LEFT_INSET=18
MUSIC_RIGHT_INSET=$MUSIC_LEFT_INSET
MUSIC_BUTTON_GAP=5
MUSIC_PREV_WIDTH=46
MUSIC_PLAY_WIDTH=64
MUSIC_CONTROL_HEIGHT=$STAT_TILE_HEIGHT
MUSIC_BUTTON_HEIGHT=72
MUSIC_BUTTON_RADIUS=12
MUSIC_BUTTON_BG=0x33000000
MUSIC_TRACK_WIDTH=393
MUSIC_LABEL_WIDTH=373
MUSIC_TRACK_HEIGHT=$STAT_TILE_HEIGHT
MUSIC_RADIUS=$STAT_RADIUS
MUSIC_PAGE_CHARS=46

# Clear all items on reload.
sketchybar --remove '/.*/' 2>/dev/null

##### Bottom gutter bar #####
# Keep the asymmetric fake margin layout:
# real margin = 340; internal right padding fakes the 640px right boundary.
sketchybar --bar \
  position=bottom \
  height=$BAR_HEIGHT \
  margin=340 \
  color=$BAR_BG \
  corner_radius=$BAR_RADIUS \
  border_width=0 \
  blur_radius=0 \
  padding_left=142 \
  padding_right=322 \
  sticky=on \
  topmost=window \
  shadow=off \
  font_smoothing=on

##### Defaults #####
sketchybar --default \
  padding_left=3 \
  padding_right=3 \
  icon.font="Hack Nerd Font:Bold:13.0" \
  label.font="Hack Nerd Font:Bold:13.0" \
  icon.color=$TEXT \
  label.color=$TEXT \
  icon.padding_left=4 \
  icon.padding_right=4 \
  label.padding_left=4 \
  label.padding_right=4

##### Left cluster: integrated two-clock pill #####

# Selectable secondary timezone. Click opens popup.
sketchybar --add item clock.left left \
  --set clock.left \
    width=150 \
    icon="AZ ▾" \
    label="--:--" \
    icon.font="Hack Nerd Font:Bold:12.0" \
    label.font="Hack Nerd Font:Bold:20.0" \
    icon.color=$BLUE \
    label.color=$TEXT \
    icon.align=center \
    label.align=center \
    icon.y_offset=21 \
    label.y_offset=-10 \
    background.drawing=off \
    padding_left=10 \
    padding_right=4 \
    popup.drawing=off \
    popup.horizontal=off \
    popup.height=34 \
    popup.blur_radius=20 \
    popup.background.color=$PANEL_STRONG \
    popup.background.corner_radius=14 \
    script="$PLUGIN_DIR/clock.sh" \
    update_freq=5 \
    click_script="sketchybar --set clock.left popup.drawing=toggle"

# Primary Arizona clock.
sketchybar --add item clock left \
  --set clock \
    width=285 \
    icon="SUN  JUN 21" \
    label="12:52 PM" \
    icon.font="Hack Nerd Font:Bold:14.0" \
    label.font="Hack Nerd Font:Bold:35.0" \
    icon.color=$CYAN \
    label.color=$TEXT \
    icon.align=center \
    label.align=center \
    icon.y_offset=26 \
    label.y_offset=-7 \
    background.drawing=off \
    padding_left=4 \
    padding_right=10 \
    script="$PLUGIN_DIR/clock.sh" \
    update_freq=5 \
    click_script="open -a Calendar"

# One shared visible clock background.
sketchybar --add bracket clock.tile clock.left clock \
  --set clock.tile \
    background.color=$PANEL_STRONG \
    background.height=$CLOCK_TILE_HEIGHT \
    background.corner_radius=17 \
    background.border_width=1 \
    background.border_color=$BORDER

# Popup timezone options.
TZ_POPUP_COMMON=(
  icon.drawing=off
  width=170
  label.font="Hack Nerd Font:Bold:13.0"
  label.color=$TEXT
  label.align=left
  background.height=28
  background.corner_radius=8
  background.color=0x22000000
)

sketchybar --add item clock.tz.et popup.clock.left \
  --set clock.tz.et "${TZ_POPUP_COMMON[@]}" \
    label="Eastern" \
    click_script="$PLUGIN_DIR/clock_select.sh America/New_York ET $BLUE"

sketchybar --add item clock.tz.ct popup.clock.left \
  --set clock.tz.ct "${TZ_POPUP_COMMON[@]}" \
    label="Central" \
    click_script="$PLUGIN_DIR/clock_select.sh America/Chicago CT $GREEN"

sketchybar --add item clock.tz.mt popup.clock.left \
  --set clock.tz.mt "${TZ_POPUP_COMMON[@]}" \
    label="Mountain" \
    click_script="$PLUGIN_DIR/clock_select.sh America/Denver MT $YELLOW"

sketchybar --add item clock.tz.pt popup.clock.left \
  --set clock.tz.pt "${TZ_POPUP_COMMON[@]}" \
    label="Pacific" \
    click_script="$PLUGIN_DIR/clock_select.sh America/Los_Angeles PT $ORANGE"

sketchybar --add item clock.tz.az popup.clock.left \
  --set clock.tz.az "${TZ_POPUP_COMMON[@]}" \
    label="Arizona" \
    click_script="$PLUGIN_DIR/clock_select.sh America/Phoenix AZ $CYAN"

sketchybar --add item clock.tz.utc popup.clock.left \
  --set clock.tz.utc "${TZ_POPUP_COMMON[@]}" \
    label="UTC" \
    click_script="$PLUGIN_DIR/clock_select.sh UTC UTC $MUTED"

sketchybar --add item clock.tz.london popup.clock.left \
  --set clock.tz.london "${TZ_POPUP_COMMON[@]}" \
    label="London" \
    click_script="$PLUGIN_DIR/clock_select.sh Europe/London LDN $BLUE"

sketchybar --add item clock.tz.tokyo popup.clock.left \
  --set clock.tz.tokyo "${TZ_POPUP_COMMON[@]}" \
    label="Tokyo" \
    click_script="$PLUGIN_DIR/clock_select.sh Asia/Tokyo TYO $RED"

sketchybar --add event clock_update
sketchybar --subscribe clock clock_update
sketchybar --subscribe clock.left clock_update

##### Left cluster: music #####

# Gap between clock pill and music controls.
sketchybar --add item gap.clock_music left \
  --set gap.clock_music \
    width=$MUSIC_GAP \
    icon.drawing=off \
    label.drawing=off \
    background.drawing=off \
    padding_left=0 \
    padding_right=0

sketchybar --add item music.left_pad left \
  --set music.left_pad \
    width=$MUSIC_LEFT_INSET \
    icon.drawing=off \
    label.drawing=off \
    background.drawing=off \
    padding_left=0 \
    padding_right=0

sketchybar --add item music.prev left \
  --set music.prev \
    width=$MUSIC_PREV_WIDTH \
    icon="⏮" \
    icon.font="Hack Nerd Font:Bold:22.0" \
    icon.width=$MUSIC_PREV_WIDTH \
    icon.align=center \
    icon.padding_left=0 \
    icon.padding_right=0 \
    label.drawing=off \
    background.drawing=on \
    background.color=$MUSIC_BUTTON_BG \
    background.height=$MUSIC_BUTTON_HEIGHT \
    background.corner_radius=$MUSIC_BUTTON_RADIUS \
    padding_left=0 \
    padding_right=0 \
    click_script="nowplaying-cli previous"

sketchybar --add item music.prev_play_gap left \
  --set music.prev_play_gap \
    width=$MUSIC_BUTTON_GAP \
    icon.drawing=off \
    label.drawing=off \
    background.drawing=off \
    padding_left=0 \
    padding_right=0

sketchybar --add item music.play left \
  --set music.play \
    width=$MUSIC_PLAY_WIDTH \
    icon="▶" \
    icon.font="Hack Nerd Font:Bold:30.0" \
    icon.width=$MUSIC_PLAY_WIDTH \
    icon.align=center \
    icon.padding_left=0 \
    icon.padding_right=0 \
    label.drawing=off \
    background.drawing=on \
    background.color=$MUSIC_BUTTON_BG \
    background.height=$MUSIC_BUTTON_HEIGHT \
    background.corner_radius=$MUSIC_BUTTON_RADIUS \
    padding_left=0 \
    padding_right=0 \
    click_script="nowplaying-cli togglePlayPause"

sketchybar --add item music left \
  --set music \
    icon.drawing=off \
    label="Nothing playing" \
    width=$MUSIC_TRACK_WIDTH \
    label.font="Hack Nerd Font:Bold:17.0" \
    label.max_chars=$MUSIC_PAGE_CHARS \
    label.width=$MUSIC_LABEL_WIDTH \
    label.align=left \
    label.padding_left=8 \
    label.padding_right=12 \
    scroll_texts=off \
    background.drawing=off \
    padding_left=0 \
    padding_right=2 \
    click_script='open -a "Amazon Music"'

sketchybar --add item music.next left \
  --set music.next \
    width=$MUSIC_CONTROL_WIDTH \
    icon="⏭" \
    icon.font="Hack Nerd Font:Bold:22.0" \
    icon.width=$MUSIC_CONTROL_WIDTH \
    icon.align=center \
    icon.padding_left=0 \
    icon.padding_right=0 \
    label.drawing=off \
    background.drawing=on \
    background.color=$MUSIC_BUTTON_BG \
    background.height=$MUSIC_BUTTON_HEIGHT \
    background.corner_radius=$MUSIC_BUTTON_RADIUS \
    padding_left=0 \
    padding_right=0 \
    click_script="nowplaying-cli next"

sketchybar --add item music.right_pad left \
  --set music.right_pad \
    width=$MUSIC_RIGHT_INSET \
    icon.drawing=off \
    label.drawing=off \
    background.drawing=off \
    padding_left=0 \
    padding_right=0

sketchybar --add bracket music.tile music.left_pad music.prev music.prev_play_gap music.play music music.next music.right_pad \
  --set music.tile \
    background.color=$PANEL_STRONG \
    background.height=$MUSIC_TRACK_HEIGHT \
    background.corner_radius=$MUSIC_RADIUS \
    background.border_width=1 \
    background.border_color=$BORDER

sketchybar --set music \
  script="$PLUGIN_DIR/music.sh" \
  update_freq=2

##### Right cluster: graph-only stats with anchored overlays #####
# Add right-side graphs/gaps in this order so visible order is:
# SWP | 20px | MEM | 20px | CPU.

# CPU graph, rightmost / largest.
sketchybar --add graph cpu.total right 350 \
  --set cpu.total \
    icon.drawing=off \
    label.drawing=off \
    background.color=0x00000000 \
    background.height=$STAT_TILE_HEIGHT \
    background.corner_radius=$STAT_RADIUS \
    graph.color=$CYAN \
    graph.fill_color=0x337bdff2 \
    graph.line_width=1.5 \
    padding_left=0 \
    padding_right=0

sketchybar --add item gap.mem_cpu right \
  --set gap.mem_cpu \
    width=$STAT_ITEM_GAP \
    icon.drawing=off \
    label.drawing=off \
    background.drawing=off \
    padding_left=0 \
    padding_right=0

# MEM graph, middle.
sketchybar --add graph mem.graph right 250 \
  --set mem.graph \
    icon.drawing=off \
    label.drawing=off \
    background.color=0x00000000 \
    background.height=$STAT_TILE_HEIGHT \
    background.corner_radius=$STAT_RADIUS \
    graph.color=$BLUE \
    graph.fill_color=0x3389b4fa \
    graph.line_width=1.5 \
    padding_left=0 \
    padding_right=0

sketchybar --add item gap.swap_mem right \
  --set gap.swap_mem \
    width=$STAT_ITEM_GAP \
    icon.drawing=off \
    label.drawing=off \
    background.drawing=off \
    padding_left=0 \
    padding_right=0

# SWP graph, leftmost of stats cluster.
sketchybar --add graph swap.graph right 250 \
  --set swap.graph \
    icon.drawing=off \
    label.drawing=off \
    background.color=0x00000000 \
    background.height=$STAT_TILE_HEIGHT \
    background.corner_radius=$STAT_RADIUS \
    graph.color=$ORANGE \
    graph.fill_color=0x33c77d47 \
    graph.line_width=1.5 \
    padding_left=0 \
    padding_right=0

# Tile backgrounds.
sketchybar --add bracket cpu.tile cpu.total \
  --set cpu.tile \
    background.color=$PANEL_STRONG \
    background.height=$STAT_TILE_HEIGHT \
    background.corner_radius=$STAT_RADIUS \
    background.border_width=1 \
    background.border_color=0x22000000

sketchybar --add bracket mem.tile mem.graph \
  --set mem.tile \
    background.color=$PANEL_STRONG \
    background.height=$STAT_TILE_HEIGHT \
    background.corner_radius=$STAT_RADIUS \
    background.border_width=1 \
    background.border_color=0x22000000

sketchybar --add bracket swap.tile swap.graph \
  --set swap.tile \
    background.color=$PANEL_STRONG \
    background.height=$STAT_TILE_HEIGHT \
    background.corner_radius=$STAT_RADIUS \
    background.border_width=1 \
    background.border_color=0x22000000

# Fitted external backing. The real bar is transparent; this bracket tracks the
# first/last visible objects without adding extra end padding.
sketchybar --add bracket main.tile clock.left clock gap.clock_music music.left_pad music.prev music.prev_play_gap music.play music music.next music.right_pad swap.graph gap.swap_mem mem.graph gap.mem_cpu cpu.total \
  --set main.tile \
    background.color=$MAIN_CELL \
    background.height=$STAT_TILE_HEIGHT \
    background.corner_radius=$STAT_RADIUS \
    background.border_width=1 \
    background.border_color=$BORDER

# CPU overlays, anchored before cpu.total.
sketchybar --add item cpu.name right \
  --set cpu.name \
    icon.drawing=off \
    label="CPU" \
    width=0 \
    label.width=52 \
    label.align=left \
    label.font="Hack Nerd Font:Bold:10.0" \
    label.color=$CYAN \
    label.y_offset=$STAT_LABEL_Y_OFFSET \
    background.drawing=off \
    padding_left=-338 \
    padding_right=0

sketchybar --add item cpu.value right \
  --set cpu.value \
    icon.drawing=off \
    label="   0%" \
    width=0 \
    label.width=66 \
    label.align=right \
    label.font="Hack Nerd Font:Bold:10.0" \
    label.color=$TEXT \
    label.y_offset=$STAT_LABEL_Y_OFFSET \
    background.drawing=off \
    padding_left=-72 \
    padding_right=0

sketchybar --move cpu.name before cpu.total
sketchybar --move cpu.value before cpu.total

# MEM overlays, anchored before mem.graph.
sketchybar --add item mem.name right \
  --set mem.name \
    icon.drawing=off \
    label="MEM" \
    width=0 \
    label.width=52 \
    label.align=left \
    label.font="Hack Nerd Font:Bold:10.0" \
    label.color=$BLUE \
    label.y_offset=$STAT_LABEL_Y_OFFSET \
    background.drawing=off \
    padding_left=-238 \
    padding_right=0

sketchybar --add item mem.value right \
  --set mem.value \
    icon.drawing=off \
    label="  0%" \
    width=0 \
    label.width=58 \
    label.align=right \
    label.font="Hack Nerd Font:Bold:10.0" \
    label.color=$TEXT \
    label.y_offset=$STAT_LABEL_Y_OFFSET \
    background.drawing=off \
    padding_left=-64 \
    padding_right=0

sketchybar --move mem.name before mem.graph
sketchybar --move mem.value before mem.graph

# SWP overlays, anchored before swap.graph.
sketchybar --add item swap.name right \
  --set swap.name \
    icon.drawing=off \
    label="SWP" \
    width=0 \
    label.width=52 \
    label.align=left \
    label.font="Hack Nerd Font:Bold:10.0" \
    label.color=$ORANGE \
    label.y_offset=$STAT_LABEL_Y_OFFSET \
    background.drawing=off \
    padding_left=-238 \
    padding_right=0

sketchybar --add item swap.value right \
  --set swap.value \
    icon.drawing=off \
    label="  0%" \
    width=0 \
    label.width=58 \
    label.align=right \
    label.font="Hack Nerd Font:Bold:10.0" \
    label.color=$TEXT \
    label.y_offset=$STAT_LABEL_Y_OFFSET \
    background.drawing=off \
    padding_left=-64 \
    padding_right=0

sketchybar --move swap.name before swap.graph
sketchybar --move swap.value before swap.graph

##### Stats driver — keep after all stat items #####
sketchybar --add item stats.driver right \
  --set stats.driver \
    drawing=off \
    updates=on \
    update_freq=2 \
    script="$PLUGIN_DIR/stats_push.sh"

sketchybar --update
